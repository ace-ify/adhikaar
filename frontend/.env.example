# Adhikaar Frontend — Environment Variables
# Copy this to .env.local and fill in your keys

# Groq API (free at console.groq.com) — primary LLM for text chat
GROQ_API_KEY=

# Google Gemini API (ai.google.dev) — backup LLM
GEMINI_API_KEY=

# Sarvam AI (sarvam.ai) — Indian-language STT/TTS/Translation
SARVAM_API_KEY=

# LiveKit Cloud (cloud.livekit.io) — voice call infrastructure
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# myScheme.gov.in API — government scheme discovery
MYSCHEME_API_KEY=
