# Adhikaar Voice Agent — Environment Variables
# Copy this to .env.local and fill in your keys

# LiveKit Cloud (cloud.livekit.io) — must match frontend config
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google Gemini API (ai.google.dev) — for Gemini Live API realtime voice
GOOGLE_API_KEY=
